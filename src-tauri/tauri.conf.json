{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Pares Radix",
  "version": "1.55.5",
  "identifier": "ai.plures.radix",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pares Radix",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost 'self'",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self'",
        "font-src": "'self' data:"
      }
    },
    "trayIcon": {
      "id": "radix-tray",
      "iconPath": "icons/32x32.png",
      "tooltip": "Pares Radix"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "msi",
      "deb",
      "appimage",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Praxis base application desktop shell",
    "longDescription": "Pares Radix — plugin-driven Praxis platform with inference engine, UX contracts, and LLM integration."
  },
  "plugins": {
    "shell": {},
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDMDRDNjhGRTI5NzAzQTYKUldTbUE1ZmlqOFlFekVEQ3NNL01rNnZUWUMwd0NoZkUrbEwwcWJubDdhNncxcm9tdVY2bC9KVHQK",
      "endpoints": [
        "https://github.com/plures/pares-radix/releases/latest/download/latest.json"
      ]
    }
  }
}
