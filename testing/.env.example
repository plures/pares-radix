# testing/.env.example — Required secrets for real testing
# Copy to .env and fill in real values. NEVER commit .env itself.
#
# These are the same keys pares-radix needs in production.
# The praxisbot pattern: real keys, real APIs, no mocks.

# LLM Provider (at least one required for MCP server)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# GitHub (for repo/issue operations)
GITHUB_TOKEN=ghp_...

# Logging
RUST_LOG=info

# PluresDB (if using external instance)
# PLURESDB_URL=http://pluresdb:3200

# MCP Server config
MCP_SERVER_PORT=3100
MCP_SERVER_HOST=0.0.0.0
