# Secrets / API keys for pares-radix testing
# Copy this to .env and fill in real values.
# NEVER commit .env — only .env.example goes in git.

# ─── Model Provider ──────────────────────────────────────────────────────────
# GitHub Models / Azure AI inference
PARES_MODEL_URL=https://models.inference.ai.azure.com
PARES_MODEL=claude-sonnet-4.5
PARES_API_KEY=

# Deep model for escalation
PARES_DEEP_MODEL=claude-opus-4.6
PARES_DEEP_MODEL_URL=

# ─── Telegram (optional — only if testing Telegram channel) ──────────────────
PARES_TELEGRAM_TOKEN=

# ─── GitHub (for Copilot auth or GitHub tools) ───────────────────────────────
GITHUB_TOKEN=

# ─── Service Mode ────────────────────────────────────────────────────────────
# Set to "serve" for full agent, "tui" for interactive, or empty for SSH-only
PARES_AUTOSTART=
