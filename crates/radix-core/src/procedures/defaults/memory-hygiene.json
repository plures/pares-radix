{
  "staleness-on-access": {
    "description": "Before search, flag stale results such as hardcoded lists and outdated counts.",
    "trigger": {
      "kind": "before_search"
    },
    "steps": [
      {
        "kind": "search",
        "params": {
          "query": "$input.query",
          "limit": 8
        },
        "as": "results"
      },
      {
        "kind": "transform",
        "params": {
          "inputs": ["$results"],
          "instruction": "Flag likely stale memories: hardcoded lists, old counts, deprecated references.",
          "mode": "structured"
        },
        "as": "staleness"
      },
      {
        "kind": "emit",
        "params": {
          "event": "memory-staleness-detected",
          "data": "$staleness"
        }
      }
    ]
  },
  "supersede-on-store": {
    "description": "After store, detect and mark superseded memories.",
    "trigger": {
      "kind": "after_store"
    },
    "steps": [
      {
        "kind": "search",
        "params": {
          "query": "$input.text",
          "limit": 8
        },
        "as": "candidate_matches"
      },
      {
        "kind": "transform",
        "params": {
          "inputs": ["$candidate_matches", "$input"],
          "instruction": "Identify records superseded by the new memory and output mark-superseded actions.",
          "mode": "structured"
        },
        "as": "superseded"
      },
      {
        "kind": "emit",
        "params": {
          "event": "memory-supersede-review",
          "data": "$superseded"
        }
      }
    ]
  },
  "memory-hygiene": {
    "description": "Daily hygiene sweep for stale, duplicate, and missing-tag memories.",
    "trigger": {
      "kind": "cron",
      "every": "24h"
    },
    "steps": [
      {
        "kind": "search",
        "params": {
          "query": "*",
          "limit": 200
        },
        "as": "memories"
      },
      {
        "kind": "transform",
        "params": {
          "inputs": ["$memories"],
          "instruction": "Report stale, duplicate, and untagged memories for maintenance.",
          "mode": "structured"
        },
        "as": "hygiene_report"
      },
      {
        "kind": "emit",
        "params": {
          "event": "memory-hygiene-report",
          "data": "$hygiene_report"
        }
      }
    ]
  },
  "memory-relevance-decay": {
    "description": "Daily relevance decay for unaccessed memories when newer duplicates exist.",
    "trigger": {
      "kind": "cron",
      "every": "24h"
    },
    "steps": [
      {
        "kind": "search",
        "params": {
          "query": "*",
          "limit": 200
        },
        "as": "all_memories"
      },
      {
        "kind": "transform",
        "params": {
          "inputs": ["$all_memories"],
          "instruction": "Find unaccessed memories with fresher duplicates and produce relevance demotion updates.",
          "mode": "structured"
        },
        "as": "decay_updates"
      },
      {
        "kind": "emit",
        "params": {
          "event": "memory-relevance-decay-applied",
          "data": "$decay_updates"
        }
      }
    ]
  },
  "memory-quality-check": {
    "description": "After store, flag vague or incomplete memory captures.",
    "trigger": {
      "kind": "after_store"
    },
    "steps": [
      {
        "kind": "transform",
        "params": {
          "inputs": ["$input"],
          "instruction": "Validate specificity/completeness and flag low-quality memory entries.",
          "mode": "structured"
        },
        "as": "quality"
      },
      {
        "kind": "conditional",
        "params": {
          "condition": "$quality.is_low",
          "then_steps": [
            {
              "kind": "emit",
              "params": {
                "event": "memory-quality-low",
                "data": "$quality"
              }
            }
          ],
          "else_steps": []
        }
      }
    ]
  }
}
