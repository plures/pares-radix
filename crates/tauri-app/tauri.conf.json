{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pares Agens",
  "version": "1.42.0",
  "identifier": "com.plures.pares-agens",
  "build": {
    "frontendDist": "../../build",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../.. && pnpm install && pnpm run build",
    "beforeDevCommand": "cd ../.. && pnpm run dev -- --port 5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pares Agens",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "msi",
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libappindicator3-1"
        ]
      }
    }
  }
}
