# validation_utils.px — Validation procedures for compose/resolver integration tests

procedure validate_input:
  trigger: manual
{
    let valid = check_not_empty({ value: data });
    if valid == false {
        emit("validation_failed", { reason: "empty_input" });
    }
}

procedure sanitize:
  trigger: manual
{
    let output = strip_html({ text: input });
}
