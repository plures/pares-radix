procedure dashboard_refresh:
  trigger: periodic
    interval: "5m"
{
    // TODO: verify parallel syntax
    let data = parallel {
        metrics: {
            let m = fetch_metrics({});
            transform_metrics({ raw: m });
        }
        alerts: {
            fetch_alerts({});
        }
        status: {
            check_health({});
        }
    };
    emit("dashboard_updated", { data: data });
}
