# pipeline_composed.px
import validation_utils
import math_utils

fact config:
  max_retries: int
  timeout_ms: int

constraint timeout_sane:
  require: config.timeout_ms > 0
  severity: error
  message: "Timeout must be positive"

procedure process_request:
  trigger: manual
  validate_input {data: "request"} -> $validation
  sanitize {input: "body"} -> $clean
  double {input: $clean} -> $result
