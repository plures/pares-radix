# Force LF line endings for all text files (prevents CRLF issues in Nix builds)
* text=auto eol=lf

# Ensure these are always LF regardless of platform
*.nix text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.rs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.md text eol=lf
flake.lock text eol=lf
