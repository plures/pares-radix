# strategy.px — Strategic objectives + parity/migration/mobile backlog as data
#
# The single queryable source of "what are we driving toward, and what's the backlog."
# Consumed by the proactive work-initiation loop: work-prioritization ranks work_items by
# (strategic objective rank × gap severity × blocks_migration), the scheduled initiator fires
# the top item, and progress is measured against the CANONICAL parity rubric.
#
# GROUND TRUTH sources (2026-07-11 rebuild — supersedes the stale May audit seed):
#   - memory/radix-parity-rubric.md            → the CANONICAL 10-category rubric (authority)
#   - memory/recon-radix-agens-2026-07-06.md   → current architecture + the 3 live blockers
#   - pares-agens/crates/cli/src/{migrate,openclaw}.rs → migration orchestrator ALREADY EXISTS
#   - pares-radix/docs/transition/migration-plan.md    → the plan (do not reinvent)
#
# ARCHITECTURE (kbristol 2026-07-11 — the VS Code / GitHub Copilot model):
#   pares-radix = the APPLICATION / platform = VS CODE. The deployable you install and RUN
#                 (event loop, procedure/task executor, .px engine, PluresDB bridge, model pool,
#                 channels, subagent+RSI spine, Tauri desktop shell, AND the extension host in
#                 crates/radix-core/src/plugins/). THIS is what replaces OpenClaw and ships to
#                 desktop + phone.
#   pares-agens = an EXTENSION / plugin loaded INTO radix = GITHUB COPILOT. Provides the
#                 cognition/agent-IP capability (delegation, headroom, model/bitnet) through
#                 radix's plugin system. It is NOT a standalone app and does NOT own the runtime.
#   Correct dependency shape: radix does NOT depend on agens (verified: radix-core/Cargo.toml has
#   no agens dep). The app must not depend on its extension.
#
#   KNOWN DRIFT (unfinished extraction): radix-core still describes itself as "modules extracted
#   from pares-agens-core, which depends on this crate" and agens still carries standalone-app
#   scaffolding (a duplicate bin `pares-agens`). That is the OLD inverted (agens=app) history not
#   yet fully cleaned up. Finishing agens-as-extension is real backlog (see blk:agens-not-yet-extension).
#
# THE CENTRAL INSIGHT: the rubric scores CAPABILITY-EXISTS (it reads 100% across all 10
# categories as of 2026-05-15) — yet kbristol is STILL on OpenClaw. So "100% parity" on paper
# is NOT migration-done. The real bar is VERIFIED_RUNNING: the capability proven running in the
# radix APP (with the agens extension loaded) AND replacing the OpenClaw equivalent for kbristol,
# on desktop AND phone. Every category below carries verified_running (default false).
#
# .px-first (C-DEV-001): objectives + backlog are DATA here; ranking/initiation LOGIC lives in
# work-prioritization.px + the loop; the radix plugin/agenda crates are only the IO boundary.

# ═══════════════════════════════════════════════════════════════════════════════
# Strategic objectives — top of the priority hierarchy (kbristol 2026-07-11)
# ═══════════════════════════════════════════════════════════════════════════════

config objective_parity:
  id: "obj:parity"
  rank: 1
  title: "Pares-agens/radix parity with OpenClaw"
  definition: "the radix APP (with the agens extension loaded) natively does everything OpenClaw does for kbristol"
  done_when: "every rubric category is verified_running in the radix app, not merely scored 100% on capability-exists"
  measured_by: "memory/radix-parity-rubric.md (canonical 10-category weighted rubric)"
  source: "kbristol 2026-07-11"

config objective_migration:
  id: "obj:migration"
  rank: 2
  title: "Migration to pares-agens/radix"
  definition: "cut over to the radix app (agens loaded as an extension) as the daily driver; retire the OpenClaw dependency for kbristol"
  done_when: "the radix app runs as kbristol's assistant (Telegram + memory + cron + tools + proactive loop, agens extension loaded) on desktop AND phone, migrated from ~/.openclaw, OpenClaw decommissioned"
  depends_on: ["obj:parity", "obj:mobile"]
  prior_art: "pares-agens migrate --from ~/.openclaw (orchestrator EXISTS, dry-run capable) + pares-radix/docs/transition/migration-plan.md — RUN and VERIFY, do not reinvent"
  note: "slipped past the original June-1-2026 target; this backlog exists to drive it proactively"
  source: "kbristol 2026-07-11"

config objective_mobile:
  id: "obj:mobile"
  rank: 3
  title: "Pares-radix iOS and Android support"
  definition: "the radix app runs on kbristol's phone (iOS + Android) — the surface that makes migration real, since OpenClaw reaches kbristol via Telegram on mobile"
  done_when: "the agent app installs + runs the assistant loop on iOS + Android; device-pairing gap closed"
  blocks: "obj:migration"
  source: "kbristol 2026-07-11; .praxis/decisions/ADR-0030-mobile-tauri-targets.md"

# ═══════════════════════════════════════════════════════════════════════════════
# LIVE BLOCKERS — concrete, current, actionable (recon-radix-agens-2026-07-06)
# These are the real top-of-queue: nothing migrates until the host binary builds.
# ═══════════════════════════════════════════════════════════════════════════════

config blocker_agens_not_extension:
  id: "blk:agens-not-yet-extension"
  objective: "obj:parity"
  title: "agens still carries standalone-app scaffolding instead of being purely a radix extension"
  detail: "Per the VS Code / Copilot model, radix is the app and agens is an extension loaded into radix's plugin host (crates/radix-core/src/plugins/). But agens still declares a standalone bin `pares-agens` (duplicated across agens-cli and agens-plugin, causing LNK1104), and radix-core's own docs still say it was 'extracted from pares-agens-core'. This is unfinished extraction from the OLD inverted (agens=app) shape. Finish it: agens loads as a radix extension; remove/repurpose the standalone-app bin scaffolding."
  gap: "medium"
  blocks_migration: true
  priority_hint: "architectural correctness gate — the migration target is the RADIX app, not an agens binary"

config blocker_radix_tag_lag:
  id: "blk:radix-tag-lag"
  objective: "obj:migration"
  title: "agens pins radix v1.55.13; radix is at v1.55.14"
  detail: "one-tag lag in agens' git-pinned radix platform crates; bump when cutting the next release"
  gap: "trivial"
  blocks_migration: false

config blocker_migration_unproven:
  id: "blk:migration-unproven"
  objective: "obj:migration"
  title: "migration orchestrator exists but is unproven end-to-end against real ~/.openclaw"
  detail: "`pares-agens migrate --from ~/.openclaw --dry-run` emits memories/channels/state/procedures.json + MigrationReport. Not yet run against kbristol's live install nor loaded into a running radix app. This is the verify gate for obj:migration."
  gap: "medium"
  blocks_migration: true

# ═══════════════════════════════════════════════════════════════════════════════
# Parity rubric — the CANONICAL 10 categories (memory/radix-parity-rubric.md).
# rubric_score = capability-exists (per the rubric, 2026-05-15). verified_running = the REAL
# migration bar (default false until proven running on agens AND replacing OpenClaw for kbristol).
# NOTE: channel adapters are OUT OF SCOPE per the rubric (Telegram-first cutover); Teams is the
# only future channel and does not affect the parity score.
# ═══════════════════════════════════════════════════════════════════════════════

