# ═══════════════════════════════════════════════════════════════════════════════
# Parity math (per the canonical rubric): overall = Σ(weight × score).
# capability_parity is ~100% on paper; verified_parity is what actually gates migration and is
# recomputed from the verified_running flags by work-prioritization.px, NOT asserted here.
# ═══════════════════════════════════════════════════════════════════════════════

config parity_math:
  formula: "overall_parity = sum(category_weight × category_rubric_score) / 100"
  capability_parity_2026_05_15: 100
  verified_parity: "computed by work-prioritization.px from verified_running flags — starts near 0 because nothing is proven running-in-the-radix-app-and-replacing-OpenClaw yet"
  rubric_authority: "memory/radix-parity-rubric.md — the ONLY rubric; no ad-hoc scoring"
