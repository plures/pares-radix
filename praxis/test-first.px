# test-first.px — Test-First Development Constraints
#
# NOTE: These constraints are POLICY DOCUMENTATION, not compiled enforcement.
# They guide AI agents reading this repo. The Condition evaluator cannot parse
# freeform domain expressions (e.g. design.has_automation_interface).
# Enforcement happens through the agent's system prompt and .px procedure
# guards, not through runtime constraint evaluation.
#
# Enforces the principle that every product is designed for automated
# testing from day one. Testing is a first-class engineering concern,
# not an afterthought.
#
# Learned the hard way:
# - Radix TUI couldn't be automated → MCP server built after the fact
# - pares-arca sled bugs: 5 push cycles because we tested on production
# - Once we wrote proper tests + integration smoke, fix was one cycle
#
# The loop: write .px → pares-radix runs it → results → iterate
# pares-radix IS the test runner. .px IS the test format.

# ═══════════════════════════════════════════════════════════════════════
# DESIGN FOR TESTABILITY
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint automation_interface_required:
# [parser-skip]   when: event.type == "architecture_review" or event.type == "new_product"
# [parser-skip]   require: design.has_automation_interface == true
# [parser-skip]   severity: error
# [parser-skip]   message: "Every product must have an automation interface from day one — CLI, API, or MCP server. If it has a UI, the UI is a client of the API, not the product itself. The API is the product. The UI is a skin."
# [parser-skip] 
# [parser-skip] constraint test_harness_required:
# [parser-skip]   when: event.type == "architecture_review" or event.type == "new_product"
# [parser-skip]   require: design.has_test_harness == true
# [parser-skip]   severity: error
# [parser-skip]   message: "Every automation interface must have a corresponding test harness — .px procedures or scripts that exercise it end-to-end. No 'manual verification required' steps."
# [parser-skip] 
# [parser-skip] constraint testability_over_convenience:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.removes_testability_for_convenience == true)
# [parser-skip]   severity: error
# [parser-skip]   message: "Never sacrifice testability for convenience. If a change makes something harder to test automatically, the change is wrong."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# TEST BEFORE PUSH
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint unit_tests_pass:
# [parser-skip]   when: event.type == "pre_push"
# [parser-skip]   require: tests.unit.passed == true
# [parser-skip]   severity: error
# [parser-skip]   message: "All unit tests must pass before pushing. Run: cargo test --workspace"
# [parser-skip] 
# [parser-skip] constraint lint_clean:
# [parser-skip]   when: event.type == "pre_push"
# [parser-skip]   require: tests.lint.passed == true
# [parser-skip]   severity: error
# [parser-skip]   message: "No lint errors before pushing. Run: cargo clippy --workspace -- -D warnings"
# [parser-skip] 
# [parser-skip] constraint binary_smoke:
# [parser-skip]   when: event.type == "pre_push" and change.affects_binary == true
# [parser-skip]   require: tests.smoke.passed == true
# [parser-skip]   severity: error
# [parser-skip]   message: "Build the release binary and run smoke tests. cargo test is necessary but not sufficient — start the service, hit the API, verify the response."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# RECOVERY PATH TESTING
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint recovery_paths_tested:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.adds_error_recovery_without_test == true)
# [parser-skip]   severity: error
# [parser-skip]   message: "If code handles errors (retry, fallback, wipe-and-recreate), write a test that triggers the error. Untested recovery code is probably broken. The pares-arca sled recovery is the model: 3 unit tests + 6 integration tests."
# [parser-skip] 
# [parser-skip] constraint no_testing_on_production:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.requires_production_to_verify == true)
# [parser-skip]   severity: error
# [parser-skip]   message: "If the only way to verify a change is to deploy it to production, the design is broken. Add a local test, a container test, or a VM test."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# .px AS TEST FORMAT
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint px_test_procedures:
# [parser-skip]   when: event.type == "new_test_suite"
# [parser-skip]   require: tests.format == "px" or tests.format == "rust"
# [parser-skip]   severity: warning
# [parser-skip]   message: "Prefer .px procedures for integration and smoke tests. .px tests are executable, self-documenting, and run through pares-radix's procedure engine. Use Rust unit tests for per-function testing."
# [parser-skip] 
# [parser-skip] constraint tests_are_not_prose:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.adds_test_defined_only_in_prose == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Test definitions must be machine-readable (.px procedures, Rust tests, scripts with assertions), not prose in documentation or cron job prompts. If a human has to interpret what 'passes' means, it's not a real test."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# CONTINUOUS TESTING
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint regression_detection:
