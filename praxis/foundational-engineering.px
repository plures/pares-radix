# foundational-engineering.px — Foundational Software Engineering Principles
#
# NOTE: These constraints are POLICY DOCUMENTATION, not compiled enforcement.
# They guide AI agents reading this repo. The Condition evaluator cannot parse
# freeform domain expressions (e.g. change.duplicates_logic_across_modules).
# Enforcement happens through the agent's system prompt and .px procedure
# guards, not through runtime constraint evaluation.
#
# These are not opinions or preferences. They are tested, universal principles
# of functional software development, codified as enforceable constraints.
#
# When the LLM (or a human) identifies a violation of one of these principles
# during review, the response is:
#   1. Fix the immediate violation
#   2. Create a targeted ADR documenting the specific case
#   3. Add a .px constraint or CI check that enforces it procedurally
#
# Each constraint here maps to a foundational tenet. Targeted ADRs reference
# these foundations and add specificity for particular codebases.
#
# This file is shared across pares-agens and pares-radix.

# ═══════════════════════════════════════════════════════════════════════
# SINGLE SOURCE OF TRUTH
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint single_source_of_truth:
# [parser-skip]   when: event.type == "pr_audit" or event.type == "commit_audit"
# [parser-skip]   require: NOT (change.duplicates_logic_across_modules == true)
# [parser-skip]   severity: error
# [parser-skip]   message: "Every piece of knowledge must have a single, unambiguous, authoritative representation. If you're fixing the same bug in two places, extract first, then fix once."
# [parser-skip] 
# [parser-skip] constraint consumers_delegate_not_duplicate:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.reimplements_existing_function == true)
# [parser-skip]   severity: error
# [parser-skip]   message: "Consumers of shared logic must delegate to the canonical implementation. A wrapper may adapt the interface but must not re-implement behavior."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# SEPARATION OF CONCERNS
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint clear_module_boundaries:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.mixes_infrastructure_and_business_logic == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Infrastructure concerns (I/O, networking, persistence) must be separated from business logic. If a function does both, split it."
# [parser-skip] 
# [parser-skip] constraint interface_over_implementation:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.depends_on_concrete_type_where_trait_exists == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Depend on traits/interfaces, not concrete implementations. This enables testing, substitution, and evolution without cascading changes."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# SMALL, PURE, COMPOSABLE FUNCTIONS
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint favor_pure_functions:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.adds_side_effects_to_pure_function == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Favor pure functions (output depends only on input, no side effects). Side effects should be pushed to the edges, not mixed into core logic."
# [parser-skip] 
# [parser-skip] constraint function_does_one_thing:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.function_has_multiple_responsibilities == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Each function should do one thing. If a function name requires 'and' to describe, it should be two functions."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# MAKE INVALID STATES UNREPRESENTABLE
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint use_types_for_correctness:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.uses_string_where_enum_exists == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Use the type system to make invalid states unrepresentable. Prefer enums over strings, newtypes over raw primitives, and Option/Result over sentinel values."
# [parser-skip] 
# [parser-skip] constraint errors_are_values:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.uses_panic_for_recoverable_error == true)
# [parser-skip]   severity: error
# [parser-skip]   message: "Recoverable errors must be values (Result/Option), not panics. Panics are for invariant violations, not expected failure modes."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# DON'T EMBED WHAT CHANGES
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint externalize_volatile_logic:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.embeds_volatile_logic_in_binary == true)
# [parser-skip]   severity: error
# [parser-skip]   message: "Logic that changes independently of the binary (scripts, config, update procedures) must not be compiled in. Use external files, config, or delegate to scripts on disk."
# [parser-skip] 
# [parser-skip] constraint configuration_over_hardcoding:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.hardcodes_environment_specific_value == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Environment-specific values (paths, URLs, hostnames, credentials) belong in configuration, not code. Use env vars, config files, or NixOS module options."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# LEVERAGE THE PLATFORM
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint use_platform_capabilities:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.reimplements_platform_feature == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Don't reimplement what the platform provides. NixOS handles builds, service lifecycle, and config management. Cargo handles dependency resolution. systemd handles restarts. Use them."
# [parser-skip] 
# [parser-skip] constraint declarative_over_imperative:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.uses_imperative_where_declarative_exists == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Prefer declarative definitions (Nix expressions, Cargo.toml, .px constraints) over imperative scripts when the platform supports it."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# FAIL FAST, FAIL CLEAR
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint fail_with_context:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.error_message_lacks_actionable_context == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Error messages must tell the user what went wrong, why, and what to do about it. 'Error: exit code 101' is not an error message."
# [parser-skip] 
# [parser-skip] constraint validate_inputs_at_boundaries:
# [parser-skip]   when: event.type == "pr_audit"
# [parser-skip]   require: NOT (change.validates_deep_instead_of_at_boundary == true)
# [parser-skip]   severity: warning
# [parser-skip]   message: "Validate inputs at system boundaries (CLI args, API requests, config loading), not deep in business logic. Once data crosses the boundary, it should be trusted."
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════════
# CORTEX-TO-CEREBELLUM LEARNING LOOP
# ═══════════════════════════════════════════════════════════════════════

# [parser-skip] constraint new_violation_class_requires_adr:
# [parser-skip]   when: event.type == "bug_fix"
# [parser-skip]   require: NOT (fix.addresses_new_violation_class == true and fix.has_corresponding_adr == false)
# [parser-skip]   severity: error
# [parser-skip]   message: "When a bug fix reveals a new class of violation (not covered by existing ADRs), create an ADR and a corresponding .px constraint or CI check before closing the fix. The LLM's recognition is expensive — commit it to a cheap procedural mechanism."
# [parser-skip] 
# [parser-skip] constraint adr_requires_enforcement:
# [parser-skip]   when: event.type == "adr_created"
# [parser-skip]   require: adr.has_corresponding_constraint == true or adr.has_corresponding_ci_check == true
# [parser-skip]   severity: error
# [parser-skip]   message: "Every ADR must have a corresponding enforcement mechanism (.px constraint, CI check, or linter rule). An ADR without enforcement is a suggestion, not a decision."
# [parser-skip] 
