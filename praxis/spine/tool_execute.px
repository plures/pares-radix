# tool_execute.px — Tool execution as a PluresDB procedure
#
# Replaces ToolExecutor (670 lines of Rust). The logic is simple:
# when model responds with tool_calls, execute each one (side-effect actors),
# then re-emit a model_request with results. PluresDB tracks iteration count.\n
procedure execute_tools:
  trigger: on_write {pattern: "model_response:*"}
  when event.has_tool_calls:
    pluresdb_increment {key: "chat:tool_iterations"}
    pluresdb_read {key: "chat:tool_iterations"} -> $iteration
    when iteration > 25:
      emit {type: "delivery_request", content: "Tool loop limit reached"}
    end
    loop over $tool_calls as tool_call:
      tool_dispatch {name: "dispatch", call_id: "call"} -> $result
      pluresdb_append {key: "chat:history", value: $result}
    end
    emit {type: "model_request", source: "tool_executor"}
  end

# Reset iteration counter when a new user message arrives
procedure reset_tool_counter:
  trigger: on_write {pattern: "inbound:*"}
  pluresdb_write {key: "chat:tool_iterations", value: 0}
