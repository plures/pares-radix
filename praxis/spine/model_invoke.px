# model_invoke.px — Model invocation as a v3 dataflow procedure
#
# Pure function: takes an enriched request (history + system prompt),
# calls the model completion action, returns structured response.
#
# Queue topology:
#
#   enriched_request ─→ [invoke_model] ─→ model_response
#

# ═══════════════════════════════════════════════════════════════════
# Dataflow Procedures
# ═══════════════════════════════════════════════════════════════════

# Invoke model completion with conversation context
procedure invoke_model(request: string from "enriched_request") -> response into "model_response":
  given: "Invoke model completion with history and system prompt"
  model_complete {
    messages: request.history,
    system_prompt: request.system_prompt
  } -> $response
  return $response
