# worktask.px — Worktask executor orchestration as .px procedures.
#
# Pure orchestration + policy logic for git-worktree task management. This file
# performs NO side effects directly: every effect (git, filesystem, durable
# state) is DESCRIBED by an action call and EXECUTED by the Rust handlers
# (CoreActionHandler for read_state/write_state; WorktaskActionHandler in
# crates/radix-core/src/spine/worktask_actions.rs for git/fs/quarantine and
# native-typed record shaping). The dangerous clean-vs-dirty reclaim DECISION
# lives here, in declarative `when` logic; Rust only runs the chosen effect
# (C-DEV-001). The 4-tier PR-mode precedence chain also lives here, as an
# explicit greedy `when`-overwrite (lowest priority first, highest last).
#
# Command surface (no CLI — the CLI crate was removed in #460): each command is
# a reactive procedure that fires when its command key is written into the live
# StateStore. A caller invokes a command by writing the command node, e.g.:
#     write  worktask:cmd:new_feature:<reqid>  =  { org, repo, branch, ... }
# The reactive registry binds that written value to `$value` (see
# spine/reactive.rs) and fires the matching procedure. Each command is mapped to
# its own key glob `worktask:cmd:<name>:*` in spine/bootstrap.rs so commands do
# not trigger each other.
#
# .px expression rules used here (validated against the pluresdb-px executor):
#   - dotted field in a string value : "${value.org}"   (dollar OUTSIDE brace)
#   - dotted field in a condition     : $st.dirty         (bare, no brace)
#   - whole-object value substitution : $task             (bare flat var)
#   - flat scalar value               : $id, $now, $mode  (bare flat var)
# `coalesce()` / `length()` are NOT available in object-literal values or string
# interpolation, so PR-mode precedence is a sequential `when`-overwrite and
# array counts go through the Rust `count` action. A loop's `-> $out` collects
# the output of the loop body's LAST top-level step per iteration, so each
# iteration ends in exactly one unconditional `make_outcome -> $row`.
#
# Durable state (C-PLURES-003 — all in PluresDB via StateStore):
#   worktask:task:{task_id}                  full task record
#   worktask:lease:{task_id}                 ownership lease (separate node)
#   worktask:policy:override:{task_id}       per-task PR-mode override (tier 1)
#   worktask:policy:repo:{org}/{repo}        repo PR-mode default      (tier 2)
#   worktask:policy:orgtype:{org}:{type}     org+type PR-mode default  (tier 3)
#   worktask:policy:global                   global PR-mode default    (tier 4)
#   worktask:reclaim:{run_id}                reclaim telemetry
#   worktask:quarantine:{task_id}            quarantine record (written by Rust)

# ─────────────────────────────────────────────────────────────────────────
# Facts (data shapes) — documentation only
# ─────────────────────────────────────────────────────────────────────────

# [parser-skip] fact Task:
# [parser-skip]   task_id: string
# [parser-skip]   org: string
# [parser-skip]   repo: string                 # repo path or org/repo slug
# [parser-skip]   task_type: enum(epic, feature, bugfix, chore)
# [parser-skip]   branch: optional[string]
# [parser-skip]   worktree_path: optional[string]
# [parser-skip]   owner_session: string
# [parser-skip]   owner_agent: string
# [parser-skip]   status: enum(planned, active, in_review, merging, done, abandoned)
# [parser-skip]   pr_mode: enum(github-pr, subagent-review, direct-merge, none)
# [parser-skip]   created_at: int
# [parser-skip]   updated_at: int
# [parser-skip]
# [parser-skip] fact Lease:
# [parser-skip]   task_id: string
# [parser-skip]   owner_session: string
# [parser-skip]   owner_agent: string
# [parser-skip]   acquired_at: int
# [parser-skip]   lease_expires_at: int

# ─────────────────────────────────────────────────────────────────────────
# Constraints — documentation only
# ─────────────────────────────────────────────────────────────────────────

# [parser-skip] constraint dirty_tree_never_deleted:
# [parser-skip]   given: "A worktree with uncommitted work must never be silently deleted"
# [parser-skip]   check: when worktree.dirty == true: action == "quarantine_worktree"
# [parser-skip]   severity: error
# [parser-skip]   message: "Dirty worktrees are quarantined (moved), never deleted. No exceptions."

# [parser-skip] constraint pr_mode_precedence_strict:
# [parser-skip]   given: "PR mode resolves override -> repo -> org+type -> global"
# [parser-skip]   severity: error

# ─────────────────────────────────────────────────────────────────────────
# Command Procedures (the 11 commands)
# ─────────────────────────────────────────────────────────────────────────

# new_epic — create an epic container task. No worktree; pr_mode none.
procedure new_epic:
  trigger: on_write
  given: "Create an epic container task (no worktree, pr_mode=none)"

  generate_id {} -> $id
  timestamp_now {} -> $now

  make_task_record {value: $value, id: $id, now: $now, task_type: "epic", status: "planned", pr_mode: "none"} -> $task
  write_state {key: "worktask:task:${id}", value: $task} -> $written

  return {task_id: $id, task_type: "epic", status: "planned", pr_mode: "none"}


# new_feature — feature task WITH a real git worktree + ownership lease.
# PR mode is resolved here via the 4-tier precedence chain (override > repo >
# org+type > global), defaulting to github-pr.
procedure new_feature:
  trigger: on_write
  given: "Create a feature task: real worktree + task node + ownership lease + resolved pr_mode"

  generate_id {} -> $id
  timestamp_now {} -> $now

  # ── resolve_pr_mode: 4-tier precedence in .px (C-DEV-001). Read each policy
  #    node, then overwrite $mode from lowest to highest priority so the
  #    highest present tier wins. This greedy when-overwrite IS the chain.
  read_state {key: "worktask:policy:override:${id}"} -> $ovr
  read_state {key: "worktask:policy:repo:${value.org}/${value.repo}"} -> $repo_pol
  read_state {key: "worktask:policy:orgtype:${value.org}:feature"} -> $orgtype_pol
  read_state {key: "worktask:policy:global"} -> $global_pol
  identity {v: "github-pr"} -> $mode
  when $global_pol != null:
    identity {v: "${global_pol.pr_mode}"} -> $mode
  end
  when $orgtype_pol != null:
    identity {v: "${orgtype_pol.pr_mode}"} -> $mode
  end
  when $repo_pol != null:
    identity {v: "${repo_pol.pr_mode}"} -> $mode
  end
  when $ovr != null:
    identity {v: "${ovr.pr_mode}"} -> $mode
  end

  # ── real git worktree creation ─────────────────────────────────────────
  git_worktree_add {repo_path: "${value.repo}", worktree_path: "${value.worktree_path}", branch: "${value.branch}"} -> $wt

  make_task_record {value: $value, id: $id, now: $now, task_type: "feature", status: "active", pr_mode: $mode} -> $task
  write_state {key: "worktask:task:${id}", value: $task} -> $w_task

  make_lease_record {value: $value, id: $id, now: $now} -> $lease
  write_state {key: "worktask:lease:${id}", value: $lease} -> $w_lease

  return {task_id: $id, task_type: "feature", status: "active", pr_mode: $mode}


