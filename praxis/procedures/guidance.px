# guidance.px - Praxis guidance generation procedure
#
# Replaces: crates/core/src/praxis/guidance.rs (325 lines of Rust)
# Generates contextual guidance blocks injected into system prompts.

procedure generate_guidance:
  trigger: manual
  given: "Generate contextual praxis guidance for the current conversation state"
  db_get_prefix {prefix: "constraint:"} -> $constraints
  db_get {key: "session:context"} -> $context
  filter_relevant {constraints: $constraints, context: $context} -> $relevant
  format_guidance_block {constraints: $relevant, session_type: $session_type} -> $guidance
  return $guidance

procedure inject_guidance:
  trigger: on_write {pattern: "model_request:*"}
  given: "Inject praxis guidance into the system prompt before model invocation"
  generate_guidance {session_type: $session_type, context: $context} -> $guidance
  pluresdb_read {key: "config:system_prompt"} -> $base_prompt
  append_guidance {base: $base_prompt, guidance: $guidance} -> $enhanced
  pluresdb_write {key: "config:system_prompt_enhanced", value: $enhanced}

procedure update_guidance_on_violation:
  trigger: on_write {pattern: "constraint.evaluation.*"}
  given: "Update guidance when a constraint violation is detected"
  db_get {key: "session:violation_history"} -> $history
  pluresdb_append {key: "session:violation_history", value: $event}
  regenerate_guidance {violations: $history} -> $updated
  pluresdb_write {key: "session:active_guidance", value: $updated}
