# model_invoke.px - Model invocation (dataflow version)
#
# Pure function: takes route + history + system_prompt, calls model, returns response.
# Fires when ALL three input queues have data.
#
# This is the effect boundary: model_complete is a side-effecting action
# (network call to LLM API). In the pure dataflow model, this procedure
# is an "actor" — it sits at the IO boundary.

procedure invoke_model(route: route from "route", history: list from "chat_history", prompt: string from "system_prompt") -> response into "model_response":
  given: "Call the model with appropriate tier based on routing decision"
  model_complete {messages: $history, system_prompt: $prompt, tier: $route.tier} -> $response
  return $response
