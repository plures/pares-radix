# self-test.px — pares-radix tests itself
#
# These procedures exercise the pares-radix MCP server and .px runtime
# using the built-in test actions. Run via:
#   praxis_run {procedure: "self_test"}
#
# This is the model for all plures project test suites:
# - .px defines the tests (executable, self-documenting)
# - pares-radix runs them (built-in actions: assert, http, process management)
# - Results flow back via MCP (structured, machine-readable)

procedure self_test:
  trigger: manual
  given: "Full self-test of pares-radix .px runtime and built-in actions"
  emit {event: "test.suite.start", suite: "self_test"}

  # Test 1: Assert actions work
  assert_eq {actual: 1, expected: 1, message: "basic integer equality"}
  assert_eq {actual: "hello", expected: "hello", message: "string equality"}
  assert_contains {value: "hello world", contains: "world", message: "substring check"}
  assert_ok {value: true, message: "truthy assertion"}
  emit {event: "test.pass", name: "assertions"}

  # Test 2: Shell execution works
  exec {command: "echo 'radix-self-test'"} -> $echo_result
  assert_eq {actual: $echo_result.stdout, expected: "radix-self-test", message: "shell exec echo"}
  emit {event: "test.pass", name: "shell_exec"}

  # Test 3: File I/O works
  write_file {path: "/tmp/radix-self-test.txt", content: "test-data-42"}
  read_file {path: "/tmp/radix-self-test.txt"} -> $file_content
  assert_contains {value: $file_content, contains: "test-data-42", message: "file roundtrip"}
  exec {command: "rm /tmp/radix-self-test.txt"}
  emit {event: "test.pass", name: "file_io"}

  # Test 4: JSON parsing works
  json_parse {text: "{\"status\": \"ok\", \"count\": 42}"} -> $parsed
  assert_eq {actual: $parsed.status, expected: "ok", message: "json parse field"}
  emit {event: "test.pass", name: "json_parse"}

  # Test 5: Sleep doesn't error
  sleep {ms: 50}
  emit {event: "test.pass", name: "sleep"}

  emit {event: "test.suite.complete", suite: "self_test", passed: 5}

procedure smoke_test_mcp:
  trigger: manual
  given: "Verify the MCP server is responsive and tools are registered"
  # This procedure runs INSIDE the MCP server, so if it executes at all,
  # the server is alive. But we can also verify tool availability.
  echo {status: "mcp_alive"} -> $ping
  assert_eq {actual: $ping.status, expected: "mcp_alive", message: "MCP echo roundtrip"}
  emit {event: "test.pass", name: "mcp_responsive"}

procedure test_process_lifecycle:
  trigger: manual
  given: "Verify start_process and stop_process work correctly"
  start_process {command: "python3 -m http.server 19876"} -> $server
  assert_ok {value: $server.pid, message: "server started with PID"}
  wait_for_ready {url: "http://localhost:19876", timeout_secs: 5}
  http_get {url: "http://localhost:19876"} -> $response
  assert_eq {actual: $response.status, expected: 200, message: "server responds 200"}
  stop_process {pid: $server.pid}
  sleep {ms: 500}
  emit {event: "test.pass", name: "process_lifecycle"}
