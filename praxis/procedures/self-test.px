# self-test.px - Self-test procedures for verifying spine integrity
#
# Run during startup or on-demand to verify all subsystems work.

procedure test_classification(test_message: string) -> test_result:
  given: "Test that classification produces valid output"
  classify_message {message: $test_message, plugins: [], last_topic: ""} -> $classification
  validate_classification {result: $classification} -> $valid
  return {test: "classification", passed: $valid, result: $classification}

procedure test_memory_roundtrip(test_key: string, test_value: string) -> test_result:
  given: "Test that memory write/read roundtrip works"
  pluresdb_write {key: $test_key, value: $test_value}
  pluresdb_read {key: $test_key} -> $readback
  return {test: "memory_roundtrip", passed: $readback, expected: $test_value}

procedure test_model_invocation(tier: string) -> test_result:
  given: "Test that model invocation returns a valid response"
  model_complete {messages: [{role: "user", content: "Say hello in exactly one word."}], tier: $tier} -> $response
  return {test: "model_invoke", tier: $tier, passed: true, response: $response}

procedure run_all_self_tests(config: string) -> test_suite_result:
  given: "Run the complete self-test suite"
  test_classification {test_message: "What is the weather?"} -> $t1
  test_memory_roundtrip {test_key: "test:selftest", test_value: "ok"} -> $t2
  test_model_invocation {tier: "fast"} -> $t3
  return {tests: [$t1, $t2, $t3], all_passed: true}
