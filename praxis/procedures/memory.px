# Memory Procedures — .px Reactive Memory System

## on_conversation_complete
# Fires when a full turn (user → model → tools → response) completes.
# Extracts facts, decisions, entities and writes them as indexed nodes.

procedure on_conversation_complete
  trigger: pluresdb_write("conversation:*:response:*")
  
  steps:
    # 1. Read the full turn (message + response + tool results)
    read turn from trigger.node_path
    
    # 2. Extract entities (names, paths, repos, decisions)
    call extract_entities(turn.content) -> entities
    
    # 3. For each entity, upsert into PluresDB
    for entity in entities:
      call pluresdb_upsert("entity:{entity.type}:{entity.name}", entity)
    
    # 4. Determine if this turn contains a decision or learning
    call classify_turn(turn) -> classification
    
    when classification.is_decision:
      call compute_embedding(classification.summary) -> embedding
      call pluresdb_write("memory:decision:{turn.id}", {
        content: classification.summary,
        embedding: embedding,
        source_turn: turn.id,
        timestamp: now(),
        decay_weight: 1.0
      })
    
    when classification.is_learning:
      call compute_embedding(classification.summary) -> embedding
      call pluresdb_write("memory:learning:{turn.id}", {
        content: classification.summary,
        embedding: embedding,
        source_turn: turn.id,
        timestamp: now(),
        decay_weight: 1.0
      })

## on_session_start
# Fires when a new conversation session begins.
# Loads relevant context from memory nodes.

procedure on_session_start
  trigger: pluresdb_write("session:*:start")
  
  steps:
    # Find recent high-relevance memories
    call pluresdb_query("memory:*", {
      sort_by: "decay_weight * recency_score",
      limit: 20
    }) -> recent_memories
    
    # Write session context node (used by ModelInvoker for system prompt)
    call pluresdb_write("session:{session_id}:context", {
      memories: recent_memories,
      loaded_at: now()
    })

## periodic_consolidate
# Runs on schedule (not on trigger). Merges duplicates, decays old memories.

procedure periodic_consolidate
  trigger: cron("0 */6 * * *")  # every 6 hours
  
  steps:
    # 1. Find memories with similar embeddings
    call pluresdb_query("memory:*") -> all_memories
    call find_duplicates(all_memories, threshold: 0.92) -> duplicate_groups
    
    # 2. Merge duplicates (keep newest, aggregate sources)
    for group in duplicate_groups:
      call merge_memories(group) -> merged
      call pluresdb_write("memory:{merged.type}:{merged.id}", merged)
      for old in group.others:
        call pluresdb_delete(old.path)
    
    # 3. Decay old memories
    call pluresdb_query("memory:*", { older_than: "7d" }) -> aging
    for mem in aging:
      let new_weight = mem.decay_weight * 0.95
      when new_weight < 0.1:
        call pluresdb_delete(mem.path)
      otherwise:
        call pluresdb_update(mem.path, { decay_weight: new_weight })

## memory_search (tool interface)
# This is what the agent calls — it queries the pre-indexed PluresDB nodes.

procedure memory_search
  input: query, limit
  
  steps:
    call compute_embedding(query) -> query_embedding
    call pluresdb_query("memory:*") -> candidates
    call cosine_rank(query_embedding, candidates, limit) -> results
    return results
