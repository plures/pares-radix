# Memory Procedures — .px Reactive Memory System
#
# These procedures implement pares-radix's reactive memory layer.
# They fire on PluresDB writes and maintain indexed memory nodes
# for search, consolidation, and context loading.

procedure on_conversation_complete:
  trigger: on_write("conversation:*:response:*")
  given: "Extract facts, decisions, entities from a completed turn and index them"
{
    # 1. Read the full turn (message + response + tool results)
    let turn = db_get({ key: trigger.node_path });

    # 2. Extract entities (names, paths, repos, decisions)
    let entities = extract_entities({ content: turn.content });

    # 3. For each entity, upsert into PluresDB
    for entity in entities {
        db_put({ key: "entity:{entity.type}:{entity.name}", value: entity });
    }

    # 4. Determine if this turn contains a decision or learning
    let classification = classify_turn({ turn: turn });

    if classification.is_decision {
        let embedding = compute_embedding({ text: classification.summary });
        db_put({ key: "memory:decision:{turn.id}", value: {
            content: classification.summary,
            embedding: embedding,
            source_turn: turn.id,
            timestamp: now(),
            decay_weight: 1.0
        }});
    }

    if classification.is_learning {
        let embedding = compute_embedding({ text: classification.summary });
        db_put({ key: "memory:learning:{turn.id}", value: {
            content: classification.summary,
            embedding: embedding,
            source_turn: turn.id,
            timestamp: now(),
            decay_weight: 1.0
        }});
    }
}

procedure on_session_start:
  trigger: on_write("session:*:start")
  given: "Load relevant context from memory nodes into session context"
{
    # Find recent high-relevance memories
    let recent_memories = db_query({ prefix: "memory:*", sort_by: "decay_weight * recency_score", limit: 20 });

    # Write session context node (used by ModelInvoker for system prompt)
    db_put({ key: "session:{session_id}:context", value: {
        memories: recent_memories,
        loaded_at: now()
    }});
}

procedure periodic_consolidate:
  trigger: cron("0 */6 * * *")
  given: "Merge duplicate memories and decay old ones"
{
    # 1. Find memories with similar embeddings
    let all_memories = db_query({ prefix: "memory:*" });
    let duplicate_groups = find_duplicates({ memories: all_memories, threshold: 0.92 });

    # 2. Merge duplicates (keep newest, aggregate sources)
    for group in duplicate_groups {
        let merged = merge_memories({ group: group });
        db_put({ key: "memory:{merged.type}:{merged.id}", value: merged });
        for old in group.others {
            db_delete({ key: old.path });
        }
    }

    # 3. Decay old memories
    let aging = db_query({ prefix: "memory:*", older_than: "7d" });
    for mem in aging {
        let new_weight = mem.decay_weight * 0.95;
        if new_weight < 0.1 {
            db_delete({ key: mem.path });
        } else {
            db_put({ key: mem.path, value: { decay_weight: new_weight } });
        }
    }
}

procedure memory_search:
  trigger: manual
  given: "Search indexed memory nodes by semantic similarity"
{
    let query_embedding = compute_embedding({ text: input.query });
    let candidates = db_query({ prefix: "memory:*" });
    let results = cosine_rank({ query: query_embedding, candidates: candidates, limit: input.limit });
    return results;
}
