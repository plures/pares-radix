# spine-actions.px - Core spine action procedures
#
# Actions that the spine can invoke: model calls, tool dispatch, response delivery.

procedure invoke_model(route: route from "route", history: list from "chat_history", prompt: string from "system_prompt") -> response into "model_response":
  given: "Call the model with appropriate tier based on routing decision"
  model_complete {messages: $history, system_prompt: $prompt, tier: $route.tier} -> $response
  return $response

procedure dispatch_tool(tool_request: string from "tool_request") -> tool_result into "tool_result":
  given: "Dispatch a tool call and return the result"
  execute_tool {request: $tool_request} -> $result
  return $result

procedure deliver_response(response: string from "model_response", personality: personality_config from "personality") -> delivery into "delivery":
  given: "Format and deliver a model response to the user"
  format_response {response: $response, personality: $personality} -> $styled
  return $styled
