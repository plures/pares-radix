# constraint-eval.px - Constraint evaluation procedures
#
# Evaluates praxis constraints against current state and produces
# violations or validations.

procedure evaluate_constraint(constraint_name: string, state: string) -> evaluation:
  given: "Evaluate a single praxis constraint against current state"
  db_get {key: "constraint:" } -> $constraint
  check_condition {constraint: $constraint, state: $state} -> $result
  when result.violated:
    return {status: "violated", constraint: $constraint_name, details: $result}
  end
  return {status: "satisfied", constraint: $constraint_name}

procedure evaluate_all_constraints(state: string) -> evaluations:
  given: "Evaluate all active constraints against current state"
  db_get_prefix {prefix: "constraint:"} -> $constraints
  loop over $constraints as constraint:
    evaluate_constraint {constraint_name: $constraint, state: $state} -> $result
  end
  return {results: $constraints}

procedure enforce_violation(violation: string from "constraint_violation") -> enforcement into "enforcement_action":
  given: "Take enforcement action on a constraint violation"
  determine_severity {violation: $violation} -> $severity
  when severity.level == "error":
    return {action: "block", reason: $violation}
  end
  when severity.level == "warning":
    return {action: "warn", reason: $violation}
  end
  return {action: "log", reason: $violation}

procedure update_constraint(constraint_name: string, new_definition: string) -> updated:
  given: "Update an existing constraint definition"
  db_get {key: "constraint:" } -> $existing
  validate_constraint {definition: $new_definition} -> $valid
  when valid.errors:
    return {status: "invalid", errors: $valid}
  end
  pluresdb_write {key: "constraint:" , value: $new_definition}
  return {status: "updated", constraint: $constraint_name}
