# classify.px - Message classification procedure
#
# Replaces: cerebellum/classifier.rs (~800 lines of Rust)
# Pure function: classify an inbound message by intent, complexity, and needs.

fact classification:
  intent: string
  complexity: int
  topic: string
  topic_shift: bool
  needs_tools: bool
  needs_deep_model: bool
  plugin_match: string
  completion_hint: string

procedure classify_message(message: string, plugins: list, last_topic: string) -> classification:
  given: "Classify a message by intent, complexity, topic, and routing needs"
  normalize_text {text: $message} -> $lower
  detect_intent {text: $lower} -> $intent
  score_complexity {text: $message} -> $complexity
  detect_tools_needed {text: $lower} -> $needs_tools
  match_plugin {text: $lower} -> $plugin_match
  extract_topic {text: $message} -> $topic
  detect_topic_shift {topic: $topic} -> $topic_shift
  determine_model_tier {complexity: $complexity} -> $needs_deep_model
  return $classification

procedure classify_with_llm(message: string, system_prompt: string) -> classification:
  given: "Use an LLM to classify messages that are ambiguous to heuristics"
  model_complete {messages: [{role: "user", content: $message}], system_prompt: $system_prompt, tier: "fast"} -> $result
  parse_classification {raw: $result} -> $classification
  return $classification
