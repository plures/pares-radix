# context-window.px - Context window management procedures
#
# Manages token budgets, context truncation, and window optimization.

procedure estimate_tokens(text: string) -> token_count:
  given: "Estimate token count for a text string"
  count_tokens {text: $text} -> $count
  return $count

procedure truncate_to_window(messages: list, max_tokens: int) -> truncated:
  given: "Truncate message history to fit within a token window"
  estimate_total_tokens {messages: $messages} -> $total
  when total <= $max_tokens:
    return $messages
  end
  prioritize_messages {messages: $messages, budget: $max_tokens} -> $prioritized
  return $prioritized

procedure select_context_window(model_tier: string, context_size: int) -> window_config:
  given: "Determine context window configuration based on model tier and content size"
  estimate_context_window {tier: $model_tier} -> $max_window
  when context_size > $max_window:
    return {overflow: true, max_window: $max_window, actual: $context_size, action: "cascade_up"}
  end
  return {overflow: false, max_window: $max_window, actual: $context_size, action: "proceed"}

procedure optimize_context(messages: list, tools: list, system_prompt: string) -> optimized:
  given: "Optimize context allocation across messages, tools, and system prompt"
  estimate_tokens {text: $system_prompt} -> $prompt_tokens
  estimate_total_tokens {messages: $messages} -> $message_tokens
  estimate_total_tokens {messages: $tools} -> $tool_tokens
  allocate_budget {prompt: $prompt_tokens, messages: $message_tokens, tools: $tool_tokens} -> $budget
  truncate_to_window {messages: $messages, max_tokens: $budget} -> $truncated
  return {messages: $truncated, budget_used: $budget}
