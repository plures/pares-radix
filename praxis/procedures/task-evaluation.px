# task-evaluation.px — Periodic task evaluation and execution
# Triggered by cron every 60s
# Evaluates pending tasks, executes ready ones, reports results

procedure evaluate_tasks:
  trigger: cron {schedule: "* * * * *"}
  given: "Evaluate all pending tasks and execute those that are ready"
  timestamp_now {} -> $now
  db_get_prefix {prefix: "task:"} -> $tasks
  loop over $tasks as task:
    check_task_ready {task: $task, now: $now} -> $ready
    when ready.is_ready:
      db_put {key: "task:running", value: $task}
      dispatch_task {task: $task} -> $result
      db_put {key: "task:completed", value: $result}
      emit {type: "task.completed", task_id: $task}
    end
  end

procedure execute_shell_task:
  trigger: manual
  given: "Execute a shell-type task"
  exec {command: "task_command"} -> $result
  timestamp_now {} -> $now
  db_put {key: "task:completed", value: $result}
  emit {type: "task.completed", task_type: "shell"}

procedure execute_procedure_task:
  trigger: manual
  given: "Execute a procedure-type task by running another .px procedure"
  praxis_run {procedure: "target"} -> $result
  timestamp_now {} -> $now
  db_put {key: "task:completed", value: $result}
  emit {type: "task.completed", task_type: "procedure"}

procedure execute_message_task:
  trigger: manual
  given: "Execute a message-type task by sending a message"
  send_message {chat_id: "target", text: "message"}
  timestamp_now {} -> $now
  db_put {key: "task:completed", value: "sent"}
  emit {type: "task.completed", task_type: "message"}

procedure create_task:
  trigger: manual
  given: "Create a new task for deferred execution"
  generate_id {} -> $id
  timestamp_now {} -> $now
  db_put {key: $id, value: "new_task"}
  emit {type: "task.created", task_id: $id}
  return $id

procedure park_task:
  trigger: manual
  given: "Park a task that is blocked on external input"
  timestamp_now {} -> $now
  db_put {key: "task:parked", value: "parked"}
  emit {type: "task.parked", reason: "blocked"}
