# [parser-skip]   piece_id: int
# [parser-skip]   from_pos: Vec2
# [parser-skip]   to_pos: Vec2
# [parser-skip]   cause: enum(wind, capture_ripple, gust, turbulence_bounce)
# [parser-skip] 
