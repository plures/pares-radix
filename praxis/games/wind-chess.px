# wind-chess.px — Wind Chess (v3 Dataflow)
#
# A real-time chess variant played in the Inner Space.
# Wind currents affect piece movement — pieces drift, captures ripple,
# and the board breathes with a 30Hz physics tick.
#
# DESIGN PILLARS (fun > architecture):
#   1. Agency over chaos — wind forecast lets you PLAN around drift
#   2. Drift captures — wind pushing your piece into enemy = capture (cackle moments)
#   3. Risk/reward weight — light pieces are fast+dangerous, heavy are safe+boring
#   4. Turbulence edges — board edges punish, not instant-kill
#   5. One gust per game — single wind-shift ability creates huge decision moments
#
# v3 dataflow: everything is a queue. Timers, inputs, physics state.
# No triggers, no on_write patterns. Pure functions connected by data flow.
#
# Queue topology:
#
#   game_clock (30Hz) ──────────────────────────┐
#   player_input ─→ [validate_move] ─→ move ─→ [apply_move] ─→ board_state
#        │                                            ↑              │
#        │                                            │              ▼
#        └─→ [use_gust] ─→ gust_event ───────────────►│    [compute_wind] ─→ wind_field
#                                                     │         │    │
#                                                     │         │    ▼
#                                                     │         │  wind_forecast (next 3 turns)
#                                                     │         │
#                                                     │         ▼
#                                                     └── [physics_tick] ─→ drift_events
#                                                              │         ↘
#                                                              │     [check_drift_captures]
#                                                              ▼              │
#                                                    [render_frame] ←─────────┘
#                                                              │
#                                                              ▼
#                                                        frame_output
#

# ═══════════════════════════════════════════════════════════════════
# Entity Schemas
# ═══════════════════════════════════════════════════════════════════

# [parser-skip] fact Piece:
# [parser-skip]   kind: enum(king, queen, rook, bishop, knight, pawn)
# [parser-skip]   color: enum(white, black)
# [parser-skip]   position: Vec2
# [parser-skip]   drift_velocity: Vec2
# [parser-skip]   weight: float         # heavier pieces resist wind more
# [parser-skip]   grounded: bool        # on a stable square vs mid-drift
# [parser-skip]   in_turbulence: bool   # caught in edge turbulence zone
# [parser-skip]   turbulence_ticks: int # how long stuck in turbulence (3 = blown off)
# [parser-skip] 
# [parser-skip] fact Vec2:
# [parser-skip]   x: float
# [parser-skip]   y: float
# [parser-skip] 
# [parser-skip] fact Board:
# [parser-skip]   pieces: list[Piece]
# [parser-skip]   wind_field: WindField
# [parser-skip]   wind_forecast: list[WindField]  # next 3 turns of wind (THE key info)
# [parser-skip]   turn: enum(white, black)
# [parser-skip]   phase: enum(waiting, animating, resolving)
# [parser-skip]   tick_count: int
# [parser-skip]   white_gust_available: bool      # one-shot wind shift ability
# [parser-skip]   black_gust_available: bool
# [parser-skip]   last_drift_captures: list[DriftCapture]  # for the schadenfreude
# [parser-skip] 
# [parser-skip] fact WindField:
# [parser-skip]   vectors: list[Vec2]   # 8x8 grid of wind vectors
# [parser-skip]   intensity: float      # global multiplier (0.0 = calm, 1.0 = gale)
# [parser-skip]   pattern: enum(steady, gusting, swirling, calm)
# [parser-skip]   seed: int             # deterministic per-game
# [parser-skip] 
# [parser-skip] fact WindForecast:
# [parser-skip]   upcoming: list[WindField]  # 3 future wind states
# [parser-skip]   confidence: list[float]    # how certain (1.0 for next, 0.7, 0.4)
# [parser-skip]   # Players see this! Planning > reacting.
# [parser-skip] 
# [parser-skip] fact MoveInput:
# [parser-skip]   player: enum(white, black)
# [parser-skip]   piece_id: int
# [parser-skip]   target: Vec2
# [parser-skip]   timestamp: int
# [parser-skip] 
# [parser-skip] fact GustInput:
# [parser-skip]   player: enum(white, black)
# [parser-skip]   direction: enum(north, south, east, west)  # 90° rotation target
# [parser-skip]   # One per game. Use it or lose it.
# [parser-skip] 
