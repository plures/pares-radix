# [parser-skip]   check: |
# [parser-skip]     # Once consumed, cannot be restored
# [parser-skip]     when event == "gust_consumed":
# [parser-skip]       assert previous_state.gust_available == true
# [parser-skip]       assert current_state.gust_available == false
# [parser-skip] 
# [parser-skip] constraint drift_capture_speed_threshold:
# [parser-skip]   severity: error
# [parser-skip]   description: "Drift captures only count above minimum speed (no gentle taps)"
# [parser-skip]   check: |
# [parser-skip]     for capture in board.last_drift_captures:
# [parser-skip]       assert capture.wind_speed >= config.drift_capture_min_speed
