# [parser-skip]   attacker_id: int      # piece that drifted INTO enemy
# [parser-skip]   victim_id: int        # piece that got hit
# [parser-skip]   attacker_kind: enum(king, queen, rook, bishop, knight, pawn)
# [parser-skip]   victim_kind: enum(king, queen, rook, bishop, knight, pawn)
# [parser-skip]   wind_speed: float     # how fast it was going (style points)
# [parser-skip]   # This is where the fun lives. A pawn drifting into a queen = legendary.
# [parser-skip] 
# [parser-skip] fact TurbulenceZone:
# [parser-skip]   edge: enum(north, south, east, west)
# [parser-skip]   depth: float          # how far in from edge (default 0.5 squares)
# [parser-skip]   bounce_strength: float # how hard it pushes back
# [parser-skip]   # Pieces in turbulence get random bounces. 3 consecutive ticks = blown off.
# [parser-skip]   # Creates dramatic near-misses instead of instant death.
# [parser-skip] 
# [parser-skip] fact Frame:
# [parser-skip]   board: Board
# [parser-skip]   drift_events: list[DriftEvent]
# [parser-skip]   drift_captures: list[DriftCapture]
# [parser-skip]   tick: int
# [parser-skip]   interpolation_alpha: float
# [parser-skip]   forecast_overlay: WindForecast  # rendered as arrows on board
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════
# Config
# ═══════════════════════════════════════════════════════════════════

# [parser-skip] config wind_chess:
# [parser-skip]   tick_rate: duration = "33ms"        # ~30Hz
# [parser-skip]   max_drift_speed: float = 2.0       # squares per second
# [parser-skip]   wind_change_interval: int = 90     # ticks between pattern shifts
# [parser-skip]   forecast_lookahead: int = 3        # how many future wind states to show
# [parser-skip]   forecast_confidence_decay: float = 0.3  # each step less certain
# [parser-skip]   turbulence_depth: float = 0.5      # edge zone width in squares
# [parser-skip]   turbulence_bounce: float = 1.5     # bounce-back force
# [parser-skip]   turbulence_death_ticks: int = 3    # consecutive ticks in zone = blown off
# [parser-skip]   gust_rotation_degrees: int = 90    # how far a gust shifts wind
# [parser-skip]   gust_intensity_multiplier: float = 1.8  # gust makes wind stronger briefly
# [parser-skip]   gust_duration_ticks: int = 15      # how long gust effect lasts (~0.5s)
# [parser-skip]   drift_capture_min_speed: float = 0.8  # minimum speed for drift to capture
# [parser-skip]   piece_weights:
# [parser-skip]     king: 5.0         # barely moves in wind (safe but slow)
# [parser-skip]     queen: 3.0        # moderate drift (versatile)
# [parser-skip]     rook: 4.0         # heavy, anchoring presence
# [parser-skip]     bishop: 2.5       # drifts on diagonals naturally
# [parser-skip]     knight: 2.0       # lightest named piece — chaotic energy
# [parser-skip]     pawn: 1.5         # lightest overall — drift missiles
# [parser-skip]   gravity_after_capture: float = 0.3  # ripple strength
# [parser-skip] 
# ═══════════════════════════════════════════════════════════════════
# Dataflow Procedures
# ═══════════════════════════════════════════════════════════════════

# ─── Input Validation ─────────────────────────────────────────────
# Pure: does the player's move obey chess rules + wind constraints?

procedure validate_move(input: MoveInput from "player_input", board: Board from "board_state") -> move into "validated_move":
  given: "Validate a player's move against current board state and wind conditions"

  # Must be this player's turn
  when input.player != board.turn:
    return null   # swallowed — not your turn
  end

  # Board must be in waiting phase (not mid-animation)
  when board.phase != "waiting":
    return null
  end

  # Find the piece
  lookup_piece {pieces: board.pieces, id: input.piece_id} -> $piece

  when $piece == null:
    return null
  end

  # Standard chess legality (ignoring wind — wind affects AFTER move)
  check_legal_move {piece: $piece, target: input.target, board: board} -> $legal

  when !$legal:
    return null
  end

  # Wind-adjusted reach: pieces fighting strong headwind have reduced range
  compute_wind_penalty {
    piece: $piece,
    target: input.target,
    wind: board.wind_field
  } -> $penalty

  when $penalty > $piece.weight:
    return null   # wind too strong for this piece to reach target
  end

  return input


# ─── Apply Move ──────────────────────────────────────────────────
# Takes a validated move + current board, produces new board state.
# If capture occurs, also emits a ripple event.

procedure apply_move(move: MoveInput from "validated_move", board: Board from "board_state") -> new_board into "board_state":
  given: "Apply a validated move to the board, handling captures and turn switching"

  # Move the piece
  move_piece {board: board, piece_id: move.piece_id, target: move.target} -> $new_board

  # Check for capture
  detect_capture {board: board, target: move.target, mover_color: move.player} -> $captured

  when $captured != null:
    # Capture creates a gravity ripple — nearby pieces get nudged
    emit_ripple {
      origin: move.target,
      strength: config.gravity_after_capture,
      board: $new_board
    } -> $ripple_events
    queue_push {queue: "drift_events", value: $ripple_events}
  end

  # Switch turn, enter animating phase
  set_phase {board: $new_board, phase: "animating"} -> $phased
  switch_turn {board: $phased} -> $final

  return $final


# ─── Wind Computation ────────────────────────────────────────────
# Pure function: given the current tick count and seed, compute wind vectors.
# Wind shifts every N ticks based on a deterministic noise function.

procedure compute_wind(board: Board from "board_state", tick: int from "game_clock") -> wind into "wind_field":
  given: "Compute the wind field for the current tick and generate forecast"

  # Deterministic wind from seed + tick
  perlin_wind {
    seed: board.wind_field.seed,
    tick: tick,
    change_interval: config.wind_change_interval
  } -> $vectors

  # Determine pattern from intensity distribution
  classify_wind_pattern {vectors: $vectors} -> $pattern

  # Compute global intensity
  average_magnitude {vectors: $vectors} -> $intensity

  # Generate forecast (the secret sauce for fun — lets players PLAN)
  compute_forecast {
    seed: board.wind_field.seed,
    current_tick: tick,
    lookahead: config.forecast_lookahead,
    change_interval: config.wind_change_interval
  } -> $forecast

  # Store forecast for rendering
  write_state {key: "wind_chess:forecast", value: $forecast}

  return {
    vectors: $vectors,
    intensity: $intensity,
    pattern: $pattern,
    seed: board.wind_field.seed
  }


# ─── Gust Ability ──────────────────────────────────────────────────
# ONE per game. The biggest decision you'll make.
# Do you gust early to set up a drift-capture combo?
# Or save it to blow the enemy king toward the edge?
# Either way, your opponent SEES you still have it. Fear is a resource.

procedure use_gust(input: GustInput from "gust_input", board: Board from "board_state") -> event into "gust_event":
  given: "Player uses their one-per-game gust to rotate wind 90 degrees"

  # Check if this player still has their gust
  check_gust_available {player: input.player, board: board} -> $available

  when !$available:
    return null  # already used — too bad
  end

  # Must be this player's turn
  when input.player != board.turn:
    return null
  end

  # Consume the gust (mark used)
  consume_gust {player: input.player, board: board} -> $updated_board

  # Rotate wind field 90° in chosen direction + intensity spike
  rotate_wind_field {
    wind: board.wind_field,
    direction: input.direction,
    intensity_multiplier: config.gust_intensity_multiplier
  } -> $gusted_wind

  # Apply gust effect to board
  apply_gust_to_board {
    board: $updated_board,
    wind: $gusted_wind,
    duration: config.gust_duration_ticks
  } -> $final_board

  queue_push {queue: "board_state", value: $final_board}

  return {
    player: input.player,
    direction: input.direction,
    new_wind: $gusted_wind
  }


# ─── Drift Capture Detection ────────────────────────────────────
# THE fun mechanic. Wind pushes your piece into an enemy = capture.
# A pawn drifting sideways into a queen is peak wind-chess.
# Minimum speed threshold prevents incidental taps from counting.

procedure check_drift_captures(drift: list[DriftEvent] from "drift_events", board: Board from "board_state") -> captures into "drift_captures":
  given: "Detect when drifting pieces collide with enemy pieces (drift = capture)"

  # No drift, no captures
  when drift == []:
    return []
  end

  define $captures = []
  define $drift_list = drift

  # Check each drift event for collision with enemy piece
  loop over $drift_list as event:
    # Get the drifting piece
    lookup_piece {pieces: board.pieces, id: event.piece_id} -> $attacker

    # Is there an enemy piece at the destination?
    find_piece_at {pieces: board.pieces, position: event.to_pos, exclude_id: event.piece_id} -> $victim

    when $victim == null:
      continue
    end

    # Must be enemy (friendly fire doesn't count)
    when $attacker.color == $victim.color:
      continue
    end

    # Must be going fast enough (no gentle taps)
    compute_drift_speed {from_pos: event.from_pos, to_pos: event.to_pos, dt: config.tick_rate} -> $speed

    when $speed >= config.drift_capture_min_speed:
      # CAPTURE! Remove victim, record the glory
      remove_piece {board: board, piece_id: $victim.id} -> $updated_board
      queue_push {queue: "board_state", value: $updated_board}

      append_to {list: $captures, value: {
        attacker_id: $attacker.id,
        victim_id: $victim.id,
        attacker_kind: $attacker.kind,
        victim_kind: $victim.kind,
        wind_speed: $speed
      }}
    end
  end

  return $captures


# ─── Turbulence Zones ────────────────────────────────────────────
# Board edges are NOT instant death. They're turbulence.
# Piece enters edge zone → random bouncing for up to 3 ticks.
# If still in zone after 3 → blown off. Creates near-misses.
# Players get a chance to rescue (move piece inward on their turn).
# The tension of watching your piece bounce at the edge = *chef's kiss*

procedure apply_turbulence(board: Board from "board_state", tick: int from "game_clock") -> drift into "drift_events":
  given: "Apply turbulence bouncing to pieces in edge zones"

  define $turbulence_events = []
  define $blown_off = []
  define $all_pieces = board.pieces

  # Check each piece for edge proximity
  loop over $all_pieces as piece:
    check_in_turbulence_zone {
      position: piece.position,
      board_size: 8,
      zone_depth: config.turbulence_depth
    } -> $in_zone

    when !$in_zone:
      # Reset turbulence counter if piece escaped
      when piece.in_turbulence:
        reset_turbulence {piece_id: piece.id, board: board} -> $_
      end
      continue
    end

    # Piece IS in turbulence zone
    increment_turbulence {piece_id: piece.id, board: board} -> $ticks_in_zone

    when $ticks_in_zone >= config.turbulence_death_ticks:
      # Blown off! (the dramatic moment)
      append_to {list: $blown_off, value: piece}
      remove_piece {board: board, piece_id: piece.id} -> $updated
      queue_push {queue: "board_state", value: $updated}
      continue
    end

    # Still alive — random bounce back toward center
    compute_turbulence_bounce {
      piece: piece,
      board_size: 8,
      bounce_strength: config.turbulence_bounce
    } -> $bounce

    apply_force {piece_id: piece.id, force: $bounce, board: board} -> $_

    append_to {list: $turbulence_events, value: {
      piece_id: piece.id,
      from_pos: piece.position,
      to_pos: $bounce.target,
      cause: "turbulence_bounce"
    }}
  end

  # Check if a blown-off piece was a king (game over!)
  check_king_blown {blown_pieces: $blown_off} -> $king_lost
  when $king_lost != null:
    queue_push {queue: "game_end", value: {loser: $king_lost.color, reason: "king_blown_off_board"}}
  end

  return $turbulence_events


# ─── Physics Tick ────────────────────────────────────────────────
# The heartbeat. Every 33ms, apply wind to all pieces that aren't grounded.
# Pieces drift, collide, settle. Pure computation.

procedure physics_tick(board: Board from "board_state", wind: WindField from "wind_field", tick: int from "game_clock") -> drift into "drift_events":
  given: "Apply wind physics to all pieces for one tick"

  # Only run physics during animating phase
  when board.phase != "animating":
    return null   # quiescent — no physics while waiting for input
  end

  # For each piece: apply wind force / weight = acceleration
  apply_wind_forces {
    pieces: board.pieces,
    wind: wind,
    max_speed: config.max_drift_speed,
    dt: config.tick_rate
  } -> $forces

  # Integrate velocities, compute new positions
  integrate_positions {pieces: board.pieces, forces: $forces, dt: config.tick_rate} -> $moved

  # Detect collisions (pieces can't overlap squares)
  resolve_collisions {pieces: $moved, board_size: 8} -> $resolved

  # Check if all pieces have settled (velocity < epsilon)
  all_settled {pieces: $resolved} -> $settled

  # Emit drift events for anything that moved
  compute_drift_deltas {old_pieces: board.pieces, new_pieces: $resolved} -> $events

  # If everything settled, transition back to waiting phase
  when $settled:
    write_state {key: "board_phase", value: "waiting"}
    switch_turn_if_needed {board: board} -> $_
  end

  return $events


# ─── Frame Rendering ─────────────────────────────────────────────
# Takes board state + drift events, produces a renderable frame.
# The inner-space canvas consumes these frames.

procedure render_frame(board: Board from "board_state", drift: list[DriftEvent] from "drift_events", captures: list[DriftCapture] from "drift_captures", tick: int from "game_clock") -> frame into "frame_output":
  given: "Compose a renderable frame with forecast overlay and drift capture highlights"

  # Compute interpolation alpha for smooth animation
  compute_alpha {tick: tick, phase: board.phase} -> $alpha

  # Get current forecast for overlay rendering
  read_state {key: "wind_chess:forecast"} -> $forecast

  return {
    board: board,
    drift_events: drift,
    drift_captures: captures,
    tick: tick,
    interpolation_alpha: $alpha,
    forecast_overlay: $forecast
  }


# ═══════════════════════════════════════════════════════════════════
# Clock Source
# ═══════════════════════════════════════════════════════════════════
# The game_clock is a PluresDB timer queue that pushes tick counts at 30Hz.
# Configured at game start, stopped on game end.

trigger game_clock:
  on: timer
  schedule: "every 33ms"
  run: tick_counter
  # condition: read_state {key: "wind_chess:active"} == true

procedure tick_counter() -> tick into "game_clock":
  given: "Increment and emit tick count"
  read_state {key: "wind_chess:tick"} -> $current
  increment {value: $current} -> $next
  write_state {key: "wind_chess:tick", value: $next}
  return $next


# ═══════════════════════════════════════════════════════════════════
# Game Lifecycle
# ═══════════════════════════════════════════════════════════════════

procedure start_game(request: string from "game_start") -> board into "board_state":
  given: "Initialize a new wind-chess game with starting positions, wind seed, and gust abilities"

  # Standard chess starting positions
  init_standard_board {} -> $pieces

  # Random seed for deterministic wind
  random_seed {} -> $seed

  # Initial wind (calm at start, builds over first 30 ticks)
  init_wind {seed: $seed, intensity: 0.0, pattern: "calm"} -> $wind

  # Pre-compute forecast so players can plan from turn 1
  compute_forecast {
    seed: $seed,
    current_tick: 0,
    lookahead: config.forecast_lookahead,
    change_interval: config.wind_change_interval
  } -> $initial_forecast

  # Mark game active
  write_state {key: "wind_chess:active", value: true}
  write_state {key: "wind_chess:tick", value: 0}
  write_state {key: "wind_chess:forecast", value: $initial_forecast}

  return {
    pieces: $pieces,
    wind_field: $wind,
    wind_forecast: $initial_forecast,
    turn: "white",
    phase: "waiting",
    tick_count: 0,
    white_gust_available: true,
    black_gust_available: true,
    last_drift_captures: []
  }

procedure end_game(board: Board from "board_state") -> result into "game_result":
  given: "Check for game-ending conditions (checkmate, stalemate, king blown off via turbulence)"

  # King blown off board via turbulence = loss (the signature wind-chess moment)
  # Note: this is now handled by apply_turbulence pushing to "game_end" queue
  # but we also check here for the case where a drift-capture took the king
  check_king_captured {captures: board.last_drift_captures} -> $king_captured

  when $king_captured != null:
    write_state {key: "wind_chess:active", value: false}
    return {winner: opponent($king_captured), reason: "king_drift_captured"}
  end

  # Standard checkmate
  check_checkmate {board: board} -> $mated

  when $mated != null:
    write_state {key: "wind_chess:active", value: false}
    return {winner: opponent($mated), reason: "checkmate"}
  end

  # Stalemate (no legal moves considering wind)
  check_stalemate_with_wind {board: board} -> $stale

  when $stale:
    write_state {key: "wind_chess:active", value: false}
    return {winner: null, reason: "stalemate"}
  end

  return null  # game continues


