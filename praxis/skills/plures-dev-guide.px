# plures-dev-guide.px — Pointer to real procedures in plures/development-guide
#
# The executable .px procedures live in the development-guide repo:
#   github:plures/development-guide/procedures/
#
# Files:
#   - work-prioritization.px    (5-level priority hierarchy decision tree)
#   - repo-routing.px           (Code ownership routing + boundary definitions)
#   - automation-first.px       (Automation safety evaluation + constraints)
#   - reactive-architecture.px  (Reactive compliance checking)
#   - development-lifecycle.px  (7-pillar build process enforcement)
#   - drift-prevention.px       (C-DRIFT-001 enforcement)
#   - copilot-delegation.px     (Copilot interaction rules + stalled handling)
#   - code-review-gates.px      (Pre-merge CI constraints)
#
# This file previously contained 144 auto-generated [parser-skip] constraints.
# Those were documentation, not enforcement. The procedures above are real logic.
#
# To load all org procedures, import them:

procedure load_dev_guide() -> GuideStatus into "guide_loaded":
  given: "Load plures org development guide procedures into active context"

  # Import from development-guide repo (when procedure imports are implemented)
  # For now, these are evaluated at boot from the procedures/ directory

  define $procedures = [
    "work-prioritization",
    "repo-routing",
    "automation-first",
    "reactive-architecture",
    "development-lifecycle",
    "drift-prevention",
    "copilot-delegation",
    "code-review-gates"
  ]

  return {loaded: $procedures, count: 8, source: "plures/development-guide/procedures/"}
