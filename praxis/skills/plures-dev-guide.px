# [parser-skip] 
# [parser-skip] constraint lesson_2026_03_reactive_over_cron_5:
# [parser-skip]   severity: error
# [parser-skip]   message: "Cron fails silently. A failed cron workflow does not retry, does not alert by default, and leaves no trace in the normal developer workflow. Use it only when you can tolerate missed runs."
# [parser-skip] 
# [parser-skip] constraint lesson_2026_03_reactive_over_cron_6:
# [parser-skip]   severity: error
# [parser-skip]   message: "Cron creates stale state. Any cron-driven action operates on state that may have changed since the last run. Event-driven actions operate on state at the moment the event occurs. Prefer event-driven for all lifecycle transitions."
# [parser-skip] 
# [parser-skip] constraint lesson_2026_03_reactive_over_cron_7:
# [parser-skip]   severity: error
# [parser-skip]   message: "Cron schedules accumulate. Without an audit process, every new automation adds a schedule and old ones are never removed. Maintain a workflow inventory and review cron usage quarterly."
# [parser-skip] 
# [parser-skip] constraint lesson_2026_03_reactive_over_cron_8:
# [parser-skip]   severity: error
# [parser-skip]   message: "One sweep cron is acceptable; many are a smell. If a repo has more than one cron-triggered workflow, it almost certainly has redundant automation. Consolidate to a single sweep with explicit documented purpose."
# [parser-skip] 
# [parser-skip] constraint lesson_2026_03_reactive_over_cron_9:
# [parser-skip]   severity: error
# [parser-skip]   message: "Org-wide trigger audits are necessary. Each repo's workflow triggers are invisible to other repos. Regular org-wide audits are the only way to catch trigger proliferation before it becomes a volume or correctness problem."
# [parser-skip] 
