# plures-dev-guide.px — Development guide procedure registry
#
# Loaded by pares-radix at boot from:
#   - Local: ~/.pares-radix/praxis/procedures/ (symlinked or copied)
#   - Repo: praxis/skills/plures-dev-guide.px (this file — index/loader)
#   - Source: github.com/plures/development-guide/procedures/
#
# All 11 procedure files enforce org-wide engineering standards.
# They are the AUTHORITATIVE source of truth (per C-DRIFT-001).
#
# Files (59 constraints + 18 procedures, ~1200 lines):
#   Core development:
#     - work-prioritization.px    (5-level priority hierarchy, decision tree)
#     - repo-routing.px           (code ownership routing, boundary definitions)
#     - automation-first.px       (automation safety evaluation, constraints)
#     - reactive-architecture.px  (reactive compliance checking)
#     - development-lifecycle.px  (7-pillar build process enforcement)
#     - drift-prevention.px       (C-DRIFT-001 enforcement, derivation tracking)
#   Copilot/CI:
#     - copilot-delegation.px     (Copilot interaction rules, stalled handling)
#     - code-review-gates.px      (pre-merge CI constraints: hard + soft gates)
#     - copilot-taint-detection.px (taint eval, assignment safety, queue locking)
#   Lessons-learned:
#     - cascade-detection.px      (cascade threshold, circuit breakers, rollout)
#   Quality:
#     - standards-enforcement.px  (quality gates from ADR-0009 through ADR-0018)

# [parser-skip] config — non-procedure metadata for radix loader
# config dev_guide:
#   source_repo: "plures/development-guide"
#   source_path: "procedures/"
#   total_constraints: 59
#   total_procedures: 18
#   version: "2026-06-11"

procedure load_dev_guide() -> GuideStatus into "guide_loaded":
  given: "Load plures org development guide procedures into active context"

  define $procedures = [
    "work-prioritization",
    "repo-routing",
    "automation-first",
    "reactive-architecture",
    "development-lifecycle",
    "drift-prevention",
    "copilot-delegation",
    "code-review-gates",
    "copilot-taint-detection",
    "cascade-detection",
    "standards-enforcement"
  ]

  return {loaded: $procedures, count: 11, source: "plures/development-guide/procedures/"}
