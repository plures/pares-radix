{
  "name": "@plures/pares-radix",
  "version": "1.55.33",
  "description": "Praxis base application — plugin-driven platform with inference engine, UX contracts, and LLM integration",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,svelte}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tui:dev": "cross-env RENDER_MODE=tui-css vite dev",
    "mcp": "pnpm -F @plures/radix-mcp-server start"
  },
  "keywords": [
    "praxis",
    "plugin",
    "inference",
    "platform"
  ],
  "author": "Plures",
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/plures/pares-radix.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "25.6.2",
    "eslint-plugin-plures": "workspace:*",
    "eslint-plugin-svelte": "^2.0.0",
    "globals": "17.6.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^0.43.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.1",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
    "@plures/canvas-runtime": "workspace:*",
    "@plures/design-dojo": "workspace:*",
    "@tauri-apps/api": "^2.10.1"
  }
}
